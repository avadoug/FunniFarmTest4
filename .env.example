# General
NEXT_PUBLIC_SITE_URL=https://your-vercel-project.vercel.app

# Local/demo admin starter guard. Replace with a strong value in Vercel if you want to view admin catalog data.
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Order request email for manual Cash App/PayPal/payment-by-reply flow.
# Configure these in Vercel before using checkout live.
RESEND_API_KEY=
FUNNI_FARM_ORDER_EMAIL=orders@example.com
ORDER_EMAIL_FROM=The Funni Farm Orders <orders@example.com>

# Optional future payment provider settings.
# The current checkout does not collect cards and does not require these.
PAYMENT_PROVIDER=
PAYMENT_PROVIDER_SECRET_KEY=
PAYMENT_PROVIDER_WEBHOOK_SECRET=
PAYMENT_PROVIDER_MERCHANT_ID=

# Optional future contact/newsletter email services
SENDGRID_API_KEY=
FORMSPREE_ENDPOINT=

# Future database
DATABASE_URL=
